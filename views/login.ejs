<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container" style="display: flex; align-items: center; justify-content: center; min-height: 80vh;">
        <div class="modern-card" style="width: 100%; max-width: 450px; padding: 3rem 2.5rem;">
            <h2 class="text-center text-gradient mb-6" style="font-size: 2.25rem;">Welcome Back</h2>
            <p class="text-center text-secondary mb-6">Log in to your account</p>
            
            <form id="request" action="users/login" method="POST">
                <div class="modern-form-group">
                    <label class="modern-label">Username</label>
                    <input class="modern-input" placeholder="Enter your username" type="text" name="username" required>
                </div>
                <div class="modern-form-group mb-6">
                    <label class="modern-label">Password</label>
                    <input class="modern-input" placeholder="Enter your password" type="password" name="password" required>
                </div>
                
                <div style="display: none; background-color: #fee2e2; color: #dc2626; padding: 0.75rem; border-radius: var(--radius-sm); margin-bottom: 1.25rem; font-size: 0.875rem; text-align: center;" id="loginError"></div>

                <div class="modern-form-group">
                    <button type="submit" class="modern-btn modern-btn-primary" style="width: 100%;">Login</button>
                </div>
            </form>
            
            <p class="text-center text-secondary mt-6" style="font-size: 0.875rem;">
                Don't have an account? <a href="/register" class="text-primary" style="font-weight: 500;">Register here</a>
            </p>

            <script>
                const form = document.querySelector('form#request');
                const loginError = document.querySelector('#loginError');

                form.addEventListener('submit', async (e) => {
                   e.preventDefault();

                   loginError.textContent = "";
                   loginError.style.display = "none";

                   const username = form.username.value;
                   const password = form.password.value;

                   try {
                      const res = await fetch('users/login', {
                         method: "POST",
                         body: JSON.stringify({ username, password }),
                         headers: { "Content-Type": "application/json" }
                      });

                      const contentType = res.headers.get('content-type') || '';
                      if (contentType.includes('application/json')) {
                         const data = await res.json();

                         if (data?.succeded || data?.succeeded) {
                            location.assign(data?.redirect || '/users/dashboard');
                            return;
                         }

                         if (data?.error) {
                            loginError.textContent = data.error;
                            loginError.style.display = "block";
                            return;
                         }
                      }

                      // Fallback: if server did a redirect / returned HTML
                      if (res.ok) {
                         location.assign('/users/dashboard');
                      } else {
                         loginError.textContent = "kullanıcı adı ve ya şifre hatalıdır";
                         loginError.style.display = "block";
                      }
                   } catch (err) {
                      console.log("ERR::", err);
                      loginError.textContent = "kullanıcı adı ve ya şifre hatalıdır";
                      loginError.style.display = "block";
                   }
                });
             </script>
        </div>
    </main>
<%- include("partials/_footer") %>
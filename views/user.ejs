<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container mt-8 mb-8" style="min-height: 70vh;">
        <!-- Header / Profile Info -->
        <div class="modern-card p-6 mb-8 profile-header-card">
            <div class="profile-avatar-wrapper">
                <div class="profile-avatar-container">
                    <img src="<%= user.avatar ? user.avatar.url : '/images/profile_1.jpg' %>" alt="Profile Photo" class="modern-avatar-lg profile-avatar-img">
                </div>
            </div>
            
            <h2 class="text-gradient" style="font-size: 2rem; margin-bottom: 0.5rem;"><%= user.username %></h2>
            
            <!-- Stats Bar -->
            <div class="profile-stats mb-4">
                <div class="profile-stat">
                    <span class="profile-stat-number"><%= user.followers.length %></span>
                    <span class="profile-stat-label">Followers</span>
                </div>
                <div class="profile-stat">
                    <span class="profile-stat-number"><%= user.followings.length %></span>
                    <span class="profile-stat-label">Following</span>
                </div>
                <div class="profile-stat">
                    <span class="profile-stat-number"><%= photos.length %></span>
                    <span class="profile-stat-label">Photos</span>
                </div>
            </div>
            
            <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
                <% if (!inFollowers) { %>
                    <a href="/users/<%= user._id %>/follow?_method=PUT" class="modern-btn modern-btn-primary">
                        <i class="fa fa-user-plus"></i>&nbsp;Follow
                    </a>
                <% } else { %>
                    <a href="/users/<%= user._id %>/unfollow?_method=PUT" class="modern-btn modern-btn-outline">
                        <i class="fa fa-user-times"></i>&nbsp;Unfollow
                    </a>
                <% } %>
                
                <a href="/messages/<%= user._id %>" class="modern-btn modern-btn-outline">
                    <i class="fa fa-comments"></i>&nbsp;Chat
                </a>
            </div>
        </div>

        <!-- Bio / About Section -->
        <% if (user.bio && user.bio.trim()) { %>
        <div class="modern-card p-6 mb-8">
            <h3 style="font-size: 1.25rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fa fa-info-circle" style="color: var(--accent-color);"></i> About <%= user.username %>
            </h3>
            <p class="profile-bio-text" style="margin: 0;"><%= user.bio %></p>
        </div>
        <% } %>

        <!-- User's Photos -->
        <% if (photos.length > 0) { %>
        <section class="mb-8">
            <h3 class="mb-4" style="font-size: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;"><%= user.username %>'s Photos</h3>
            <div class="modern-photo-grid">
                <% for (photo of photos) { %>
                    <a href="/photos/<%= photo._id %>" class="modern-photo-card">
                        <img src="<%= photo.url %>" alt="<%= photo.name %>">
                        <div class="modern-photo-overlay">
                            <h4 style="color: white; font-size: 1.125rem; margin-bottom: 0.25rem;"><%= photo.name %></h4>
                            <p><%= photo.description.substring(0, 80) + "..." %></p>
                        </div>
                    </a>
                <% } %>
            </div>
        </section>
        <% } %>

    </main>

<%- include("partials/_footer") %>

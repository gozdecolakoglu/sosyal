<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container mt-8 mb-8" style="min-height: 70vh;">
        <h2 class="text-gradient mb-6 text-center" style="font-size: 2.5rem;">All Users</h2>

        <!-- Search Bar -->
        <div class="users-search-wrapper mb-8">
            <form action="/users" method="GET" class="users-search-form" id="searchForm">
                <div class="users-search-input-wrapper">
                    <i class="fa fa-search users-search-icon"></i>
                    <input 
                        type="text" 
                        name="search" 
                        id="searchInput"
                        class="modern-input users-search-input" 
                        placeholder="Search users by username..." 
                        value="<%= search %>"
                        autocomplete="off"
                    >
                    <% if (search) { %>
                        <a href="/users" class="users-search-clear" title="Clear search">
                            <i class="fa fa-times"></i>
                        </a>
                    <% } %>
                </div>
            </form>
            <div class="users-search-meta">
                <% if (search) { %>
                    <span class="text-secondary" style="font-size: 0.85rem;">
                        <strong><%= totalUsers %></strong> user<%= totalUsers !== 1 ? 's' : '' %> found for "<strong><%= search %></strong>"
                    </span>
                <% } else { %>
                    <span class="text-secondary" style="font-size: 0.85rem;">
                        <strong><%= totalUsers %></strong> user<%= totalUsers !== 1 ? 's' : '' %> total
                    </span>
                <% } %>
            </div>
        </div>

        <!-- Users Grid -->
        <% if (users.length > 0) { %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
            <% for (user of users) { %>
                <div class="modern-card users-card">
                    <a href="/users/<%= user._id %>">
                        <img src="<%= user.avatar ? user.avatar.url : '/images/profile_1.jpg' %>" alt="Avatar" class="modern-avatar users-card-avatar">
                    </a>
                    <h3 style="margin-bottom: 0.5rem;">
                        <a href="/users/<%= user._id %>" class="text-primary" style="font-weight: 600; font-size: 1.25rem;"><%= user.username %></a>
                    </h3>
                    <% if (user.bio && user.bio.trim()) { %>
                        <p class="text-secondary" style="font-size: 0.85rem; margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= user.bio %></p>
                    <% } else { %>
                        <p class="text-secondary" style="font-size: 0.85rem; margin-bottom: 1rem; opacity: 0.5;">No bio yet</p>
                    <% } %>
                    <div style="display: flex; gap: 0.5rem; width: 100%;">
                        <a href="/users/<%= user._id %>" class="modern-btn modern-btn-outline" style="flex: 1;"><i class="fa fa-user"></i>&nbsp;Profile</a>
                        <a href="/messages/<%= user._id %>" class="modern-btn modern-btn-primary" style="flex: 1;"><i class="fa fa-comments"></i>&nbsp;Chat</a>
                    </div>
                </div>
            <% } %>
        </div>
        <% } else { %>
        <div class="users-empty-state">
            <i class="fa fa-users" style="font-size: 3rem; opacity: 0.3; margin-bottom: 1rem;"></i>
            <% if (search) { %>
                <p>No users found matching "<strong><%= search %></strong>"</p>
                <a href="/users" class="modern-btn modern-btn-outline mt-4">Clear Search</a>
            <% } else { %>
                <p>No other users on the platform yet.</p>
            <% } %>
        </div>
        <% } %>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <nav class="pagination-wrapper mt-8">
            <div class="pagination">
                <!-- Previous Button -->
                <% if (currentPage > 1) { %>
                    <a href="/users?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn pagination-prev">
                        <i class="fa fa-chevron-left"></i>
                    </a>
                <% } else { %>
                    <span class="pagination-btn pagination-prev disabled">
                        <i class="fa fa-chevron-left"></i>
                    </span>
                <% } %>

                <!-- Page Numbers -->
                <div class="pagination-pages">
                    <%
                        // Show max 5 page buttons with smart windowing
                        let startPage = Math.max(1, currentPage - 2);
                        let endPage = Math.min(totalPages, startPage + 4);
                        startPage = Math.max(1, endPage - 4);
                    %>

                    <% if (startPage > 1) { %>
                        <a href="/users?page=1<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn">1</a>
                        <% if (startPage > 2) { %>
                            <span class="pagination-dots">...</span>
                        <% } %>
                    <% } %>

                    <% for (let i = startPage; i <= endPage; i++) { %>
                        <a href="/users?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" 
                           class="pagination-btn <%= i === currentPage ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (endPage < totalPages) { %>
                        <% if (endPage < totalPages - 1) { %>
                            <span class="pagination-dots">...</span>
                        <% } %>
                        <a href="/users?page=<%= totalPages %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn"><%= totalPages %></a>
                    <% } %>
                </div>

                <!-- Next Button -->
                <% if (currentPage < totalPages) { %>
                    <a href="/users?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn pagination-next">
                        <i class="fa fa-chevron-right"></i>
                    </a>
                <% } else { %>
                    <span class="pagination-btn pagination-next disabled">
                        <i class="fa fa-chevron-right"></i>
                    </span>
                <% } %>
            </div>

            <p class="pagination-info text-secondary">
                Page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong>
            </p>
        </nav>
        <% } %>
    </main>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        let debounceTimer;

        if (searchInput) {
            searchInput.addEventListener('input', function() {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => {
                    document.getElementById('searchForm').submit();
                }, 600);
            });
        }
    });
    </script>

<%- include("partials/_footer") %>
<%- include("partials/_header") %>
   <body class="main-layout inner_page">
      <!-- loader  -->
       <!--  <div class="loader_bg">
         <div class="loader"><img src="images/loading.gif" alt="#"/></div>
      </div>-->
      <!-- end loader -->
      <!-- header -->
      <%- include("partials/_menu") %>
         <!-- end header inner -->
         <!-- team -->
         <div class="team">
            <div class="container_with">
               <div class="row">
                  <div class="col-md-12">
                     <div class="titlepage text_align_center">
                        <span>ALL</span>
                        <h2>Users</h2>
                     </div>
                  </div>
                  <% for (user of users) { %>
                     <div class="col-md-4">
                        <div class="team_box text_align_center">
                           <div class="team_img">
                              <a href="/users/<%= user._id %>"> <figure><img src="images/team4.png" alt="#" /></figure></a>
                           </div>
                           <div class="craig">
                              <h3>
                                 <a href="/users/<%= user._id %>"> <%= user.username %> </a>
                              </h3>
                          
                              <ul class="social_icon ">
                             
                                 <li><a href="/users/<%= user._id %>"><i class="fa fa-external-link-square"
                                          aria-hidden="true"> Profile</i></a>
                                 </li>
                                   <!-- CHAT BUTTON EKLENDİ -->
               <li>
                  <a href="/messages/<%= user._id %>">
                     <i class="fa fa-comments" aria-hidden="true"> Chat</i>
                  </a>
               </li>
                              </ul>
                           </div>
                        </div>
                     </div>
                     <% } %>
               </div>
            </div>
         </div>
         <!-- end team -->
         <!-- end footer -->
         <%- include("partials/_footer") %>
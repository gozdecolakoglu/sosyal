<header class="header-area">
    <div class="container-fluid">
       <div class="row ">
         
          <div class=" col-md-2 col-sm-3">
             <div class="logo">
                <a href="/">Social<br><span>Media</span></a>
             </div>
          </div>

          <div class="col-md-10">
            <div class="navbar-area" style="float:right ;">
                <nav class="site-navbar">
                   <ul>
                      <li><a class="<%= link === 'index' && 'active' %>" href="/"><i class="fa fa-home">
                      </i> Home</a></li>
                      <li><a class="<%= link === 'about' && 'active' %>" href="/about"><i class="fa fa-address-card"></i> About</a></li>
                      <li><a class="<%= link === 'photos' && 'active' %>" href="/photos"><i class="fa fa-picture-o">
                     </i> Photos</a></li>
                      <li><a class="<%= link === 'contact' && 'active' %>" href="/contact"><i class="fa fa-envelope-open">
                     </i> Contact</a></li>
                      <% if (user) { %>
                        <li><a class="<%= link === 'users' && 'active' %>" href="/users"><i class="fa fa-users">
                        </i> Users</a></li>
                        <li><a class="<%= link === 'dashboard' && 'active' %>" href="/users/dashboard"><i class="fa fa-user">
                        </i> Dashboard</a></li>
                        <li><a href="/logout"><i class="fa fa-sign-out" style="font-size:20px">
                        </i> Logout</a></li>
                        <% } else { %>
                          <li><a class="<%= link === 'login' && 'active' %>" href="/login"><i class="fa fa-sign-in" style="font-size:20px">
                        </i> Login</a></li>
                          <li><a class="<%= link === 'register' && 'active' %>" href="/register"><i class="fa fa-pencil">
                        </i> Register</a></li>
                          <% }%>
                   </ul>
                   <button class="nav-toggler">
                   <span></span>
                   </button> 
                </nav>
             </div>
          </div>
       </div>
    </div>
 </header>
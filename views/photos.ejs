<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container mt-8 mb-8" style="min-height: 70vh;">
        <h2 class="text-gradient mb-6 text-center" style="font-size: 2.5rem;">All Photos</h2>

        <!-- Search Bar -->
        <div class="users-search-wrapper mb-8">
            <form action="/photos" method="GET" class="users-search-form" id="searchForm">
                <div class="users-search-input-wrapper">
                    <i class="fa fa-search users-search-icon"></i>
                    <input 
                        type="text" 
                        name="search" 
                        id="searchInput"
                        class="modern-input users-search-input" 
                        placeholder="Search photos by name or description..." 
                        value="<%= search %>"
                        autocomplete="off"
                    >
                    <% if (search) { %>
                        <a href="/photos" class="users-search-clear" title="Clear search">
                            <i class="fa fa-times"></i>
                        </a>
                    <% } %>
                </div>
            </form>
            <div class="users-search-meta">
                <% if (search) { %>
                    <span class="text-secondary" style="font-size: 0.85rem;">
                        <strong><%= totalPhotos %></strong> photo<%= totalPhotos !== 1 ? 's' : '' %> found for "<strong><%= search %></strong>"
                    </span>
                <% } else { %>
                    <span class="text-secondary" style="font-size: 0.85rem;">
                        <strong><%= totalPhotos %></strong> photo<%= totalPhotos !== 1 ? 's' : '' %> total
                    </span>
                <% } %>
            </div>
        </div>

        <!-- Photos Grid -->
        <% if (photos.length > 0) { %>
        <div class="modern-photo-grid">
            <% for (photo of photos) { %>
                <a href="/photos/<%= photo._id %>" class="modern-photo-card">
                    <img src="<%= photo.url %>" alt="<%= photo.name %>">
                    <div class="modern-photo-overlay">
                        <h3 style="color: white; font-size: 1.125rem; margin-bottom: 0.25rem;"><%= photo.name.substring(0, 80) %></h3>
                        <p><%= photo.description.substring(0, 80) + "..." %></p>
                    </div>
                </a>
            <% } %>
        </div>
        <% } else { %>
        <div class="users-empty-state">
            <i class="fa fa-picture-o" style="font-size: 3rem; opacity: 0.3; margin-bottom: 1rem;"></i>
            <% if (search) { %>
                <p>No photos found matching "<strong><%= search %></strong>"</p>
                <a href="/photos" class="modern-btn modern-btn-outline mt-4">Clear Search</a>
            <% } else { %>
                <p>No photos to display yet.</p>
            <% } %>
        </div>
        <% } %>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <nav class="pagination-wrapper mt-8">
            <div class="pagination">
                <!-- Previous -->
                <% if (currentPage > 1) { %>
                    <a href="/photos?page=<%= currentPage - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn pagination-prev">
                        <i class="fa fa-chevron-left"></i>
                    </a>
                <% } else { %>
                    <span class="pagination-btn pagination-prev disabled">
                        <i class="fa fa-chevron-left"></i>
                    </span>
                <% } %>

                <!-- Page Numbers -->
                <div class="pagination-pages">
                    <%
                        let startPage = Math.max(1, currentPage - 2);
                        let endPage = Math.min(totalPages, startPage + 4);
                        startPage = Math.max(1, endPage - 4);
                    %>

                    <% if (startPage > 1) { %>
                        <a href="/photos?page=1<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn">1</a>
                        <% if (startPage > 2) { %>
                            <span class="pagination-dots">...</span>
                        <% } %>
                    <% } %>

                    <% for (let i = startPage; i <= endPage; i++) { %>
                        <a href="/photos?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" 
                           class="pagination-btn <%= i === currentPage ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (endPage < totalPages) { %>
                        <% if (endPage < totalPages - 1) { %>
                            <span class="pagination-dots">...</span>
                        <% } %>
                        <a href="/photos?page=<%= totalPages %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn"><%= totalPages %></a>
                    <% } %>
                </div>

                <!-- Next -->
                <% if (currentPage < totalPages) { %>
                    <a href="/photos?page=<%= currentPage + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="pagination-btn pagination-next">
                        <i class="fa fa-chevron-right"></i>
                    </a>
                <% } else { %>
                    <span class="pagination-btn pagination-next disabled">
                        <i class="fa fa-chevron-right"></i>
                    </span>
                <% } %>
            </div>

            <p class="pagination-info text-secondary">
                Page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong>
            </p>
        </nav>
        <% } %>
    </main>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        let debounceTimer;

        if (searchInput) {
            searchInput.addEventListener('input', function() {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => {
                    document.getElementById('searchForm').submit();
                }, 600);
            });
        }
    });
    </script>

<%- include("partials/_footer") %>
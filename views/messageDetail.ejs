<%- include("partials/_header") %>
<%- include("partials/_menu") %>

<div class="container mt-4">
  <h2>Chat with <%= otherUser.username %></h2>

  <div class="card p-3 mb-3" style="max-height:400px; overflow-y:auto;">
    <% messages.forEach(m => { %>
      <div class="<%= m.from._id.toString() === locals.user._id.toString() ? 'text-end' : 'text-start' %>">
        <strong><%= m.from.username %>:</strong> <%= m.text %>
      </div>
    <% }) %>
  </div>

  <form method="POST" action="/messages/<%= otherUser._id %>">
    <div class="input-group">
      <input type="text" name="text" class="form-control" placeholder="Type a message..." required>
      <button type="submit" class="btn btn-primary">Send</button>
    </div>
  </form>
</div>

<%- include("partials/_footer") %>

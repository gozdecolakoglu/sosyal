<%- include("partials/_header") %>
<%- include("partials/_menu") %>

<div class="container mt-5">
  <h2 class="mb-4 text-center">Chat with <%= otherUser.username %></h2>

  <div class="card shadow-sm">
    <!-- Mesajlar -->
    <div id="messagesContainer" class="card-body" style="height:400px; overflow-y:auto;">
      <% messages.forEach(m => { %>
        <div class="<%= m.from._id.toString() === locals.user._id.toString() ? 'd-flex justify-content-end' : 'd-flex justify-content-start' %> mb-2">
          <div class="<%= m.from._id.toString() === locals.user._id.toString() ? 'message-sent' : 'message-received' %> p-2 rounded">
            <strong><%= m.from.username %>:</strong> <%= m.text %>
            <div class="text-muted" style="font-size:0.75rem;">
              <%= new Date(m.createdAt).toLocaleString() %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Mesaj gönderme formu -->
    <form id="chatForm" class="p-3">
      <div class="input-group">
        <input type="text" name="text" id="chatInput" class="form-control" placeholder="Type a message..." required>
        <button type="submit" class="btn btn-primary">Send</button>
      </div>
    </form>
  </div>
</div>

<!-- jQuery (CDN) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
  $('#chatForm').submit(function(e){
    e.preventDefault(); // Sayfa yenilenmesin

    const messageText = $('#chatInput').val();
    if(!messageText) return;

    $.post('/messages/<%= otherUser._id %>', { text: messageText }, function(data){
      const now = new Date();
      const formattedTime = now.toLocaleString();

      // Mesajı mesaj container'a ekle
      $('#messagesContainer').append(`
        <div class="d-flex justify-content-end mb-2">
          <div class="message-sent p-2 rounded">
            <strong><%= locals.user.username %>:</strong> ${messageText}
            <div class="text-muted" style="font-size:0.75rem;">${formattedTime}</div>
          </div>
        </div>
      `);

      // Scroll en alta
      $('#messagesContainer').scrollTop($('#messagesContainer')[0].scrollHeight);

      // Input temizle
      $('#chatInput').val('');
    });
  });
</script>

<%- include("partials/_footer") %>

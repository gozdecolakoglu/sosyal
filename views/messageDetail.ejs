<%- include("partials/_header") %> 
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container mt-8 mb-8" style="min-height: 70vh;">
        <div class="modern-card chat-container" style="max-width: 800px; margin: 0 auto; display: flex;">
            <!-- Chat Header -->
            <div style="padding: 1.5rem; border-bottom: 1px solid var(--border-color); display: flex; align-items: center; justify-content: space-between; background: var(--bg-color);">
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <img src="<%= otherUser.avatar ? otherUser.avatar.url : '/images/profile_1.jpg' %>" alt="Avatar" class="modern-avatar">
                    <h2 style="margin: 0; font-size: 1.25rem;"><%= otherUser.username %></h2>
                </div>
                <a href="/users/<%= otherUser._id %>" class="modern-btn modern-btn-outline"><i class="fa fa-user"></i>&nbsp;Profile</a>
            </div>

            <!-- Messages List -->
            <div id="messagesContainer" style="flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; background: var(--surface-color);">
                <% messages.forEach(m => { %>
                    <% const isMe = m.from && locals.user && m.from._id.toString() === locals.user._id.toString(); %>
                    <div style="display: flex; justify-content: <%= isMe ? 'flex-end' : 'flex-start' %>; width: 100%;">
                        <div class="message-bubble <%= isMe ? 'message-me' : 'message-other' %>">
                            <% if (!isMe) { %>
                                <strong style="font-size: 0.875rem; opacity: 0.8; margin-bottom: 0.25rem; display: block;"><%= m.from ? m.from.username : 'Deleted User' %></strong>
                            <% } %>
                            <div class="message-body" style="word-break: break-word;"><%- m.text %></div>
                            <div style="font-size: 0.7rem; opacity: 0.7; margin-top: 0.5rem; text-align: right;">
                                <%= new Date(m.createdAt).toLocaleString() %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Input Area -->
            <div style="padding: 1.5rem; border-top: 1px solid var(--border-color); background: var(--bg-color);">
                <form id="chatForm">
                    <div class="modern-chat-toolbar" style="margin-bottom: 0.5rem;">
                        <button type="button" class="modern-btn modern-btn-outline toolbar-btn" style="padding: 0.25rem 0.5rem;" data-cmd="bold"><b>B</b></button>
                        <button type="button" class="modern-btn modern-btn-outline toolbar-btn" style="padding: 0.25rem 0.5rem;" data-cmd="italic"><i>I</i></button>
                        <button type="button" class="modern-btn modern-btn-outline toolbar-btn" style="padding: 0.25rem 0.5rem;" data-cmd="underline"><u>U</u></button>
                        <input type="file" id="fileInput" accept="image/*,video/*" style="display:none" />
                        <button type="button" class="modern-btn modern-btn-outline" style="padding: 0.25rem 0.6rem;" id="attachBtn" title="Attach file"><i class="fa fa-paperclip"></i></button>
                    </div>

                    <div class="modern-chat-input-row">
                        <div id="editor" contenteditable="true" class="modern-input" style="flex: 1; min-height: 50px; max-height: 150px; overflow-y: auto; position: relative;">
                            <div class="editor-placeholder" style="color: var(--text-secondary); pointer-events: none;">Type a message...</div>
                        </div>
                        <input type="hidden" name="text" id="textHidden">
                        <button type="submit" class="modern-btn modern-btn-primary" style="height: auto; align-self: flex-end;">Send</button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <style>
        .message-body img, .message-body video {
            max-width: 100%;
            border-radius: var(--radius-md);
            margin-top: 0.5rem;
        }
    </style>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        const editor = document.getElementById('editor');
        editor.addEventListener('focus', () => {
            const ph = editor.querySelector('.editor-placeholder');
            if (ph) ph.style.display = 'none';
        });
        editor.addEventListener('blur', () => {
            const text = editor.innerText.trim();
            if (!text && !editor.querySelector('img') && !editor.querySelector('video')) {
                const ph = editor.querySelector('.editor-placeholder');
                if (ph) ph.style.display = 'block';
            }
        });

        document.querySelectorAll('.toolbar-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const cmd = btn.getAttribute('data-cmd');
                document.execCommand(cmd, false, null);
                editor.focus();
            });
        });

        document.getElementById('attachBtn').addEventListener('click', () => {
            document.getElementById('fileInput').click();
        });

        document.getElementById('fileInput').addEventListener('change', function(e) {
            const file = this.files[0];
            if (!file) return;

            const allowedImage = file.type.startsWith('image/');
            const allowedVideo = file.type.startsWith('video/');
            const reader = new FileReader();

            reader.onload = function(ev) {
                const dataUrl = ev.target.result;
                let html = '';
                if (allowedImage) {
                    html = `<div><img src="${dataUrl}" alt="attachment" /></div><br/>`;
                } else if (allowedVideo) {
                    html = `<div><video controls><source src="${dataUrl}" type="${file.type}">Browser does not support video.</video></div><br/>`;
                } else {
                    alert('Only image or video allowed.');
                    return;
                }

                document.execCommand('insertHTML', false, html);
                editor.focus();
            };

            reader.readAsDataURL(file);
            this.value = '';
        });

        $('#chatForm').submit(function(e){
            e.preventDefault();

            const htmlContent = editor.innerHTML.trim();
            if (!htmlContent || htmlContent === '<div class="editor-placeholder">Type a message...</div>') return;

            $('#textHidden').val(htmlContent);

            const otherId = '<%= otherUser._id %>';

            $.ajax({
                url: '/messages/' + otherId,
                method: 'POST',
                data: { text: htmlContent },
                success: function(data){
                    const now = new Date();
                    const formattedTime = now.toLocaleString();

                    $('#messagesContainer').append(`
                        <div style="display: flex; justify-content: flex-end; width: 100%;">
                            <div style="max-width: 70%; padding: 1rem; border-radius: var(--radius-lg); background: var(--accent-gradient); color: white; border-bottom-right-radius: 0;">
                                <div class="message-body" style="word-break: break-word;">${htmlContent}</div>
                                <div style="font-size: 0.7rem; opacity: 0.7; margin-top: 0.5rem; text-align: right;">${formattedTime}</div>
                            </div>
                        </div>
                    `);

                    $('#messagesContainer').scrollTop($('#messagesContainer')[0].scrollHeight);
                    editor.innerHTML = '<div class="editor-placeholder" style="color: var(--text-secondary); pointer-events: none;">Type a message...</div>';
                },
                error: function(err){
                    alert('Message failed to send.');
                }
            });
        });

        $(document).ready(function(){
            $('#messagesContainer').scrollTop($('#messagesContainer')[0].scrollHeight);
        });
    </script>
<%- include("partials/_footer") %>

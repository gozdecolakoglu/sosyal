<%- include("partials/_header") %>
<%- include("partials/_menu") %>

<div class="container mt-5">
  <h2 class="mb-4 text-center">Chat with <%= otherUser.username %></h2>

  <div class="card shadow-sm">
    <div class="card-body" style="height:400px; overflow-y:auto;">
      <% messages.forEach(m => { %>
        <div class="<%= m.from._id.toString() === locals.user._id.toString() ? 'd-flex justify-content-end' : 'd-flex justify-content-start' %>">
  <div class="<%= m.from._id.toString() === locals.user._id.toString() ? 'message-sent' : 'message-received' %>">
    <strong><%= m.from.username %>:</strong> <%= m.text %>
  </div>
</div>
      <% }) %>
    </div>

    <form method="POST" action="/messages/<%= otherUser._id %>" class="p-3">
      <div class="input-group">
        <input type="text" name="text" class="form-control" placeholder="Type a message..." required>
        <button type="submit" class="btn btn-primary">Send</button>
      </div>
    </form>
  </div>
</div>

<%- include("partials/_footer") %>

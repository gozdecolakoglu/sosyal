<%- include("partials/_header") %>
<%- include("partials/_menu") %>

<div class="container mt-5">
  <h2 class="mb-4 text-center">Chat with <%= otherUser.username %></h2>

  <div class="card shadow-sm">
    <div class="card-body" style="height:400px; overflow-y:auto;">
      <% messages.forEach(m => { %>
        <div class="<%= m.from._id.toString() === locals.user._id.toString() ? 'd-flex justify-content-end' : 'd-flex justify-content-start' %>">
          <div class="<%= m.from._id.toString() === locals.user._id.toString() ? 'message-sent' : 'message-received' %>">
            <strong><%= m.from.username %>:</strong> <%- m.text %>
          </div>
        </div>
      <% }) %>
    </div>

    <form method="POST" action="/messages/<%= otherUser._id %>" class="p-3">
      <!-- Quill editörü için div -->
      <div id="editor" style="height:100px;"></div>
      <!-- Gizli textarea (gönderim için) -->
      <textarea name="text" id="hiddenInput" style="display:none;"></textarea>
      <button type="submit" class="btn btn-primary mt-2">Send</button>
    </form>
  </div>
</div>

<!-- Quill CSS & JS (CDN) -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<script>
  // Quill editörü başlat
  var quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Type a message...',
    modules: {
      toolbar: [
        ['bold', 'italic', 'underline'],
        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
        ['clean']
      ]
    }
  });

  // Form submit olurken textarea içine Quill içeriğini aktar
  document.querySelector('form').onsubmit = function() {
    document.querySelector('#hiddenInput').value = quill.root.innerHTML;
  };
</script>

<%- include("partials/_footer") %>

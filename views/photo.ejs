<%- include("partials/_header") %>
   <!-- body -->

   <body class="main-layout inner_page">
      <!-- loader  -->
     <!--  <div class="loader_bg">
         <div class="loader"><img src="images/loading.gif" alt="#"/></div>
      </div>-->
      <!-- end loader -->

      <!-- header -->
      <%- include("partials/_menu") %>
         <!-- end header inner -->
         <!-- about -->
         <div class="about">
            <div class="container">
               <div class="row">
                  <div class="col-md-6">
                     <div class="titlepage text_align_left">
                        <h3 style="font-size:24px !important ;">
                           <%= photo.name %>
                        </h3>
                        <p>
                           <%= photo.description %>
                        </p>
                        <a class="read_more" href="/users/<%= photo.user._id %>"> Artist: <%= photo.user.username %> <i class="fa fa-external-link-square"
                           aria-hidden="true"></i>
                          
                        </a>

                        <% if (isOwner) { %>

                           <div style="margin-top: 30px ;">
                              <ul style="display: flex; justify-content: space-between;">
                                 <li><button class="photoupdate" data-toggle="modal"
                                       data-target="#updateModal">Update</button></li>
                                 <li><a  class="photoupdate"
                                       href="/photos/<%= photo._id %>?_method=DELETE"
                                       onclick="return confirm('Do you want to delete the photo')">Delete</a></li>
                              </ul>
                           </div>

                           <% }%>
                     </div>
                  </div>
                  <div class="col-md-6">
                     <div class="about_img">
                        <figure><img style="z-index:1 ;" src="<%= photo.url %>" alt="<%= photo.name %>" /></figure>
                     </div>
                  </div>
               </div>
            </div>
         </div>
         <!-- end about -->
         <!-- end footer -->
         <div id="updateModal" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog"
            aria-labelledby="myLargeModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
               <div class="modal-content">
                  <div class="modal-header">
                     <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                     </button>
                  </div>
                  <div style="margin-top: 50px; margin-bottom: 50px;" class="container">
                     <div class="row">
                        <div class="col-md-12 ">
                           <div class="text_align_center">
                              <h2 style="
         font-size: 30px;
         margin-bottom: 20px;
         color: #D43A8E;
     ">Add New Photo</h2>
                           </div>
                        </div>
                        <div class="col-md-10 offset-md-1">
                           <form id="request" class="main_form" method="POST"
                              action="/photos/<%= photo._id %>?_method=PUT" enctype="multipart/form-data">
                              <div class="row">
                                 <div class="col-md-12">
                                    <input value="<%= photo.name %>" class="form_control" placeholder="Name" type="text"
                                       name="name">
                                 </div>
                                 <div class="col-md-12">
                                    <textarea name="description" style="height: 150px;" class="form_control"
                                       placeholder="Description" rows="5"><%= photo.description %></textarea>
                                 </div>

                                 <div style="margin-bottom: 20px ;" class="col-md-12">
                                    <input type="file" name="image" class="form-control-file">
                                 </div>

                                 <div class="col-md-12">
                                    <div class="group_form">
                                       <button class="read_more">Update Photo</button>
                                    </div>
                                 </div>
                              </div>
                           </form>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
                           <!-- Fotoğraf detaylarının altına ekle -->
                           <div class="container mt-5">
<div class="interactions" style="margin: 20px 0; display: flex; gap: 15px;">
   <% if (user) { %>
     <form action="/photos/<%= photo._id %>/like" method="POST">
       <button type="submit" class="btn <%= isLiked ? 'btn-success' : 'btn-outline-success' %>">
         👍 Like (<%= photo.likes.length %>)
       </button>
     </form>
     <form action="/photos/<%= photo._id %>/dislike" method="POST">
       <button type="submit" class="btn <%= isDisliked ? 'btn-danger' : 'btn-outline-danger' %>">
         👎 Dislike (<%= photo.dislikes.length %>)
       </button>
     </form>
   <% } else { %>
     <p>for comment, Like or dislike <a href="/users/login">login</a></p>
   <% } %>
 </div> </div>
         <!-- Yorum Formu -->
         <% if (user) { %>
            <div class="container mt-5">
              <form action="/photos/<%= photo._id %>/comments" method="POST">
                <div class="form-group">
                  <textarea class="form-control" name="text" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Send</button>
              </form>
            </div>
          <% } %>

          <!-- Yorum Listesi -->
          <div class="container mt-4">
            <% photo.comments.slice().sort((a, b) => b.createdAt - a.createdAt).forEach(comment => { %>
              <div class="card mb-3">
                <div class="card-body">
                 <h6 class="card-subtitle mb-2 text-muted">
  <%= (comment.postedBy && comment.postedBy.username) ? comment.postedBy.username : 'Bilinmeyen Kullanıcı' %> - 
  <%= comment.createdAt.toLocaleString('tr-TR') %>
</h6>
                  <p class="card-text"><%= comment.text %></p>
                </div>
              </div>
            <% }) %>
          </div>

         <%- include("partials/_footer") %>
<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container mt-8 mb-8" style="min-height: 70vh;">
        <div style="display: flex; flex-wrap: wrap; gap: 2rem;">
            <!-- Left: Photo Image -->
            <div style="flex: 1 1 60%;">
                <div class="modern-card" style="padding: 1rem; position: sticky; top: 100px;">
                    <img src="<%= photo.url %>" alt="<%= photo.name %>" style="width: 100%; border-radius: var(--radius-md);">
                </div>
            </div>

            <!-- Right: Details, Interactions, Comments -->
            <div style="flex: 1 1 35%; display: flex; flex-direction: column; gap: 1.5rem;">
                <!-- Details Card -->
                <div class="modern-card p-6">
                    <h2 class="text-gradient" style="font-size: 2rem; margin-bottom: 1rem;"><%= photo.name %></h2>
                    <p class="text-secondary mb-4"><%= photo.description %></p>
                    <a href="/users/<%= photo.user._id %>" class="modern-btn modern-btn-outline" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                        <img src="<%= photo.user.avatar ? photo.user.avatar.url : '/images/profile_1.jpg' %>" alt="Avatar" class="modern-avatar" style="width: 24px; height: 24px;">
                        Artist: <%= photo.user.username %>
                    </a>
                    
                    <% if (isOwner) { %>
                    <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                        <button class="modern-btn modern-btn-primary" style="flex: 1;" data-toggle="modal" data-target="#updateModal">Update</button>
                        <a href="/photos/<%= photo._id %>?_method=DELETE" class="modern-btn modern-btn-outline" style="flex: 1; border-color: #dc2626; color: #dc2626;" onclick="return confirm('Do you want to delete the photo')">Delete</a>
                    </div>
                    <% } %>
                </div>

                <!-- Interactions -->
                <div class="modern-card p-6">
                    <h3 style="font-size: 1.25rem; margin-bottom: 1rem;">Interactions</h3>
                    <% if (user) { %>
                        <div style="display: flex; gap: 1rem;">
                            <form action="/photos/<%= photo._id %>/like" method="POST" style="flex: 1;">
                                <button type="submit" class="modern-btn modern-btn-outline <% if (isLiked) { %> btn-liked <% } %>" style="width: 100%;">
                                    👍 Like (<%= photo.likes.length %>)
                                </button>
                            </form>
                            <form action="/photos/<%= photo._id %>/dislike" method="POST" style="flex: 1;">
                                <button type="submit" class="modern-btn modern-btn-outline <% if (isDisliked) { %> btn-disliked <% } %>" style="width: 100%;">
                                    👎 Dislike (<%= photo.dislikes.length %>)
                                </button>
                            </form>
                        </div>
                    <% } else { %>
                        <p class="text-secondary">Please <a href="/login" class="text-primary" style="font-weight: 500;">log in</a> to like, dislike, or comment.</p>
                    <% } %>
                </div>

                <!-- Comments -->
                <div class="modern-card p-6">
                    <h3 style="font-size: 1.25rem; margin-bottom: 1rem;">Comments</h3>
                    
                    <% if (user) { %>
                    <form action="/photos/<%= photo._id %>/comments" method="POST" style="margin-bottom: 2rem;">
                        <div class="modern-form-group">
                            <textarea class="modern-input" name="text" rows="3" required placeholder="Add a comment..."></textarea>
                        </div>
                        <button type="submit" class="modern-btn modern-btn-primary" style="width: 100%;">Post Comment</button>
                    </form>
                    <% } %>

                    <div style="display: flex; flex-direction: column; gap: 1rem; max-height: 500px; overflow-y: auto; padding-right: 0.5rem;">
                        <% photo.comments.slice().sort((a, b) => b.createdAt - a.createdAt).forEach(comment => { %>
                            <div class="comment-item" id="comment-<%= comment._id %>" style="padding: 1.25rem; border: 1px solid var(--border-color); border-radius: var(--radius-md); background: var(--bg-color); transition: all 0.2s ease;">
                                <!-- Comment Header -->
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem; align-items: center;">
                                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                                        <img src="<%= (comment.postedBy && comment.postedBy.avatar) ? comment.postedBy.avatar.url : '/images/profile_1.jpg' %>" alt="Avatar" class="modern-avatar" style="width: 32px; height: 32px;">
                                        <div style="display: flex; flex-direction: column;">
                                            <a href="<%= comment.postedBy ? '/users/' + comment.postedBy._id : '#' %>" style="font-weight: 600; color: var(--text-primary); font-size: 0.9rem;"><%= (comment.postedBy && comment.postedBy.username) ? comment.postedBy.username : 'Unknown User' %></a>
                                            <span class="text-secondary" style="font-size: 0.7rem;">
                                                <%= comment.createdAt.toLocaleDateString() %>
                                                <% if (comment.updatedAt) { %> 
                                                    • <span title="Last edited: <%= comment.updatedAt.toLocaleString() %>">Edited</span>
                                                <% } %>
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <!-- Comment Actions (Edit/Delete) -->
                                    <% if (user && (comment.postedBy && comment.postedBy._id.equals(user._id) || photo.user._id.equals(user._id))) { %>
                                        <div style="display: flex; gap: 0.5rem;">
                                            <% if (comment.postedBy && comment.postedBy._id.equals(user._id)) { %>
                                                <button onclick="toggleEditComment('<%= comment._id %>')" class="text-secondary" style="background: none; border: none; cursor: pointer; padding: 4px; transition: color 0.2s;" title="Edit">
                                                    <i class="fa fa-pencil"></i>
                                                </button>
                                            <% } %>
                                            <form action="/photos/<%= photo._id %>/comments/<%= comment._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this comment?')" style="display: inline;">
                                                <button type="submit" class="text-secondary" style="background: none; border: none; cursor: pointer; padding: 4px; transition: color 0.2s;" title="Delete">
                                                    <i class="fa fa-trash" style="color: #ef4444; opacity: 0.7;"></i>
                                                </button>
                                            </form>
                                        </div>
                                    <% } %>
                                </div>

                                <!-- Comment Body -->
                                <div class="comment-content-wrapper" id="content-<%= comment._id %>">
                                    <p style="margin: 0; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.5; white-space: pre-wrap;"><%= comment.text %></p>
                                </div>

                                <!-- Edit Form (Hidden by default) -->
                                <% if (user && comment.postedBy && comment.postedBy._id.equals(user._id)) { %>
                                    <form id="edit-form-<%= comment._id %>" action="/photos/<%= photo._id %>/comments/<%= comment._id %>?_method=PUT" method="POST" style="display: none; margin-top: 0.5rem;">
                                        <div class="modern-form-group" style="margin-bottom: 0.75rem;">
                                            <textarea class="modern-input" name="text" rows="3" required style="font-size: 0.9rem;"><%= comment.text %></textarea>
                                        </div>
                                        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                            <button type="button" onclick="toggleEditComment('<%= comment._id %>')" class="modern-btn modern-btn-outline" style="padding: 0.25rem 0.75rem; font-size: 0.8rem;">Cancel</button>
                                            <button type="submit" class="modern-btn modern-btn-primary" style="padding: 0.25rem 0.75rem; font-size: 0.8rem;">Save Changes</button>
                                        </div>
                                    </form>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <script>
                    function toggleEditComment(commentId) {
                        const content = document.getElementById(`content-${commentId}`);
                        const form = document.getElementById(`edit-form-${commentId}`);
                        
                        if (form.style.display === 'none') {
                            content.style.display = 'none';
                            form.style.display = 'block';
                            form.querySelector('textarea').focus();
                        } else {
                            content.style.display = 'block';
                            form.style.display = 'none';
                        }
                    }
                </script>
            </div>
        </div>

    </main>

    <!-- Update Modal -->
    <div id="updateModal" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content modern-card" style="border: none; padding: 2rem;">
                <div class="modal-header" style="border-bottom: none; padding-bottom: 0;">
                    <h3 class="text-gradient">Update Photo</h3>
                    <button type="button" class="close" data-dismiss="modal" style="background: none; border: none; font-size: 1.5rem; color: var(--text-secondary); cursor: pointer;">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form method="POST" action="/photos/<%= photo._id %>?_method=PUT" enctype="multipart/form-data">
                        <div class="modern-form-group">
                            <label class="modern-label">Title</label>
                            <input class="modern-input" value="<%= photo.name %>" type="text" name="name" required>
                        </div>
                        <div class="modern-form-group">
                            <label class="modern-label">Description</label>
                            <textarea name="description" class="modern-input" rows="4" required style="resize: vertical;"><%= photo.description %></textarea>
                        </div>
                        <div class="modern-form-group mb-6">
                            <label class="modern-label">Update Image (Optional)</label>
                            <input type="file" name="image" class="modern-input" style="padding: 0.5rem 0; border: none; background: transparent;">
                        </div>
                        <div class="modern-form-group" style="text-align: right;">
                            <button type="submit" class="modern-btn modern-btn-primary">Update Photo</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

<%- include("partials/_footer") %>
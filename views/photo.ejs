<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container mt-8 mb-8" style="min-height: 70vh;">
        <div style="display: flex; flex-wrap: wrap; gap: 2rem;">
            <!-- Left: Photo Image -->
            <div style="flex: 1 1 60%;">
                <div class="modern-card" style="padding: 1rem; position: sticky; top: 100px;">
                    <img src="<%= photo.url %>" alt="<%= photo.name %>" style="width: 100%; border-radius: var(--radius-md);">
                </div>
            </div>

            <!-- Right: Details, Interactions, Comments -->
            <div style="flex: 1 1 35%; display: flex; flex-direction: column; gap: 1.5rem;">
                <!-- Details Card -->
                <div class="modern-card p-6">
                    <h2 class="text-gradient" style="font-size: 2rem; margin-bottom: 1rem;"><%= photo.name %></h2>
                    <p class="text-secondary mb-4"><%= photo.description %></p>
                    <a href="/users/<%= photo.user._id %>" class="modern-btn modern-btn-outline" style="width: 100%;">
                        <i class="fa fa-user"></i>&nbsp;Artist: <%= photo.user.username %>
                    </a>
                    
                    <% if (isOwner) { %>
                    <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                        <button class="modern-btn modern-btn-primary" style="flex: 1;" data-toggle="modal" data-target="#updateModal">Update</button>
                        <a href="/photos/<%= photo._id %>?_method=DELETE" class="modern-btn modern-btn-outline" style="flex: 1; border-color: #dc2626; color: #dc2626;" onclick="return confirm('Do you want to delete the photo')">Delete</a>
                    </div>
                    <% } %>
                </div>

                <!-- Interactions -->
                <div class="modern-card p-6">
                    <h3 style="font-size: 1.25rem; margin-bottom: 1rem;">Interactions</h3>
                    <% if (user) { %>
                        <div style="display: flex; gap: 1rem;">
                            <form action="/photos/<%= photo._id %>/like" method="POST" style="flex: 1;">
                                <button type="submit" class="modern-btn modern-btn-outline <% if (isLiked) { %> btn-liked <% } %>" style="width: 100%;">
                                    👍 Like (<%= photo.likes.length %>)
                                </button>
                            </form>
                            <form action="/photos/<%= photo._id %>/dislike" method="POST" style="flex: 1;">
                                <button type="submit" class="modern-btn modern-btn-outline <% if (isDisliked) { %> btn-disliked <% } %>" style="width: 100%;">
                                    👎 Dislike (<%= photo.dislikes.length %>)
                                </button>
                            </form>
                        </div>
                    <% } else { %>
                        <p class="text-secondary">Please <a href="/login" class="text-primary" style="font-weight: 500;">log in</a> to like, dislike, or comment.</p>
                    <% } %>
                </div>

                <!-- Comments -->
                <div class="modern-card p-6">
                    <h3 style="font-size: 1.25rem; margin-bottom: 1rem;">Comments</h3>
                    
                    <% if (user) { %>
                    <form action="/photos/<%= photo._id %>/comments" method="POST" style="margin-bottom: 2rem;">
                        <div class="modern-form-group">
                            <textarea class="modern-input" name="text" rows="3" required placeholder="Add a comment..."></textarea>
                        </div>
                        <button type="submit" class="modern-btn modern-btn-primary" style="width: 100%;">Post Comment</button>
                    </form>
                    <% } %>

                    <div style="display: flex; flex-direction: column; gap: 1rem; max-height: 400px; overflow-y: auto;">
                        <% photo.comments.slice().sort((a, b) => b.createdAt - a.createdAt).forEach(comment => { %>
                            <div style="padding: 1.25rem; border: 1px solid var(--border-color); border-radius: var(--radius-md); background: var(--bg-color);">
                                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; align-items: center;">
                                    <span style="font-weight: 600; color: var(--text-primary);"><%= (comment.postedBy && comment.postedBy.username) ? comment.postedBy.username : 'Unknown User' %></span>
                                    <span class="text-secondary" style="font-size: 0.8rem;"><%= comment.createdAt.toLocaleDateString() %></span>
                                </div>
                                <p style="margin: 0; font-size: 0.95rem; color: var(--text-secondary);"><%= comment.text %></p>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- Update Modal -->
    <div id="updateModal" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content modern-card" style="border: none; padding: 2rem;">
                <div class="modal-header" style="border-bottom: none; padding-bottom: 0;">
                    <h3 class="text-gradient">Update Photo</h3>
                    <button type="button" class="close" data-dismiss="modal" style="background: none; border: none; font-size: 1.5rem; color: var(--text-secondary); cursor: pointer;">
                        <span>&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form method="POST" action="/photos/<%= photo._id %>?_method=PUT" enctype="multipart/form-data">
                        <div class="modern-form-group">
                            <label class="modern-label">Title</label>
                            <input class="modern-input" value="<%= photo.name %>" type="text" name="name" required>
                        </div>
                        <div class="modern-form-group">
                            <label class="modern-label">Description</label>
                            <textarea name="description" class="modern-input" rows="4" required style="resize: vertical;"><%= photo.description %></textarea>
                        </div>
                        <div class="modern-form-group mb-6">
                            <label class="modern-label">Update Image (Optional)</label>
                            <input type="file" name="image" class="modern-input" style="padding: 0.5rem 0; border: none; background: transparent;">
                        </div>
                        <div class="modern-form-group" style="text-align: right;">
                            <button type="submit" class="modern-btn modern-btn-primary">Update Photo</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

<%- include("partials/_footer") %>
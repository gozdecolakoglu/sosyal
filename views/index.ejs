      <!-- gallery -->
      <div class="gallery">
         <div class="container_with">
            <div class="row">
               <div class="col-md-12">
                  <div class="titlepage text_align_left">
                   <h2>Latest Photos</h2>
                  </div>
               </div>
            </div>
            <div class="tz-gallery">
               <div class="row">

                  <% for (photo of photos) { %>

                     <div class="col-lg-4 col-md-6 ma_bottom30">
                        <div class="lightbox">
                           <img src="<%= photo.url %>" alt="<%= photo.name %>">
                           <div class="view_main">
                              <div class="pose">
                                 <a class="read_more" href="<%= photo.url %>"><img src="images/ga.png" alt="#" /></a>
                                 <p>
                                    <%= photo.description.substring(0, 80)+ "..." %>
                                 </p>
                              </div>
                           </div>
                        </div>
                     </div>


                     <% } %>

               </div>
            </div>
         </div>
      </div>
      <!-- end gallery -->

      <!-- team -->
      <div class="team">
         <div class="container_with">
            <div class="row">

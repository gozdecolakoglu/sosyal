<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>
    
    <main class="modern-container">
        <!-- Hero Section -->
        <section class="modern-card mt-8 mb-8" style="padding: 4rem 2rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; background: linear-gradient(to right, var(--bg-color), var(--surface-color));">
            <div style="flex: 1 1 45%;">
                <h1 style="font-size: 3rem; font-weight: 800; margin-bottom: 1.5rem;" class="text-gradient">Share your best moments.</h1>
                <p class="text-secondary" style="font-size: 1.25rem; margin-bottom: 2rem;">Join the community, explore stunning photos, and connect with creative minds.</p>
                <a class="modern-btn modern-btn-primary" style="font-size: 1.125rem; padding: 0.75rem 2rem;" href="<%= user ? 'users/dashboard' : '/register' %>">Get Started</a>
            </div>
            <div style="flex: 1 1 50%; display: flex; justify-content: center; padding-top: 2rem;">
                <img src="/images/img.png" alt="Hero" style="border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); max-width: 100%;">
            </div>
        </section>

        <!-- Stats Section -->
        <section class="mb-8" style="display: flex; gap: 2rem; justify-content: center;">
            <a href="/photos" class="modern-card" style="padding: 2rem; text-align: center; flex: 1; text-decoration: none;">
                <h2 class="text-gradient" style="font-size: 2.5rem; margin: 0;"><%= numOfPhotos %></h2>
                <p class="text-secondary" style="font-weight: 500; font-size: 1.125rem; margin: 0;">Total Photos</p>
            </a>
            <a href="/users" class="modern-card" style="padding: 2rem; text-align: center; flex: 1; text-decoration: none;">
                <h2 class="text-gradient" style="font-size: 2.5rem; margin: 0;"><%= numOfUser %></h2>
                <p class="text-secondary" style="font-weight: 500; font-size: 1.125rem; margin: 0;">Active Users</p>
            </a>
        </section>

        <!-- Gallery Section -->
        <section class="mb-8">
            <h2 style="font-size: 2rem; margin-bottom: 0.5rem;">Latest Photos</h2>
            <p class="text-secondary mb-4">Discover what others are capturing around the world.</p>
            
            <div class="slider-container">
                <div class="photos-slider" id="latestPhotosSlider">
                    <% for (photo of photos) { %>
                        <div class="slider-item">
                            <a href="/photos/<%= photo._id %>" class="modern-photo-card">
                                <img src="<%= photo.url %>" alt="<%= photo.name %>">
                                <div class="modern-photo-overlay">
                                    <p><%= photo.description.substring(0, 80) + "..." %></p>
                                </div>
                            </a>
                        </div>
                    <% } %>
                </div>
                <button class="slider-nav prev" onclick="moveSlider(-1)">
                    <i class="fa fa-chevron-left"></i>
                </button>
                <button class="slider-nav next" onclick="moveSlider(1)">
                    <i class="fa fa-chevron-right"></i>
                </button>
            </div>
        </section>

        <script>
            function moveSlider(direction) {
                const slider = document.getElementById('latestPhotosSlider');
                const scrollAmount = slider.clientWidth; 
                slider.scrollBy({
                    left: direction * scrollAmount,
                    behavior: 'smooth'
                });
            }
        </script>
    </main>
    
<%- include("partials/_footer") %>
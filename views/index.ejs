<%- include("partials/_header") %>
   <!-- body -->
   <body class="main-layout">
      <!-- loader  -->
      <div class="loader_bg">
         <div class="loader"><img src="images/loading.gif" alt="#"/></div>
      </div>
      <!-- end loader -->
     
         <!-- header -->
         <%- include("partials/_menu") %>
         <!-- end header inner -->
         <!-- top -->
 <!-- Modern Banner -->
<div class="modern-banner">
  <div class="banner-content">
    <h1>ADD BEST PHOTOS</h1>
    <a class="btn-join" href="<%= user ? 'users/dashboard' : '/register' %>">Join</a>
  </div>
  <div class="banner-image">
    <img src="images/img.png" alt="Banner Image">
  </div>
</div>

<style>
  .modern-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    padding: 50px 5%;
    background: linear-gradient(to right, #faf6f8, #53358d), url('images/banner-bg.jpg') center/cover no-repeat;
    color: white;
    border-radius: 12px;
    margin-bottom: 50px;
  }

  .modern-banner .banner-content {
    flex: 1 1 45%;
    z-index: 2;
  }

  .modern-banner h1 {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 20px;
  }

  .modern-banner .btn-join {
    display: inline-block;
    padding: 12px 30px;
    background-color: #f6388e;
    color: white;
    font-weight: bold;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .modern-banner .btn-join:hover {
    background-color: #53358d;
    transform: scale(1.05);
  }

  .modern-banner .banner-image {
    flex: 1 1 50%;
    text-align: center;
  }

  .modern-banner .banner-image img {
    max-width: 100%;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  @media (max-width: 768px) {
    .modern-banner {
      flex-direction: column;
      text-align: center;
      padding: 30px 10px;
    }

    .modern-banner .banner-content, 
    .modern-banner .banner-image {
      flex: 1 1 100%;
    }

    .modern-banner h1 {
      font-size: 2rem;
    }
  }
</style>


<%- include("partials/_header") %>
<body class="modern-body">
    <%- include("partials/_menu") %>

    <main class="modern-container mt-8 mb-8" style="min-height: 70vh;">
        <h2 class="text-gradient mb-6 text-center" style="font-size: 2.5rem;">Messages</h2>

        <div class="modern-card" style="max-width: 600px; margin: 0 auto; padding: 2rem;">
            <ul id="conversationUsersList" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem;">
                <% if (conversationUsers.length === 0) { %>
                    <p class="text-secondary text-center">You have no conversations yet.</p>
                <% } else { %>
                    <% conversationUsers.forEach(user => { %>
                    <li style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; border: 1px solid var(--border-color); border-radius: var(--radius-md);">
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <img src="/images/team4.png" alt="Avatar" class="modern-avatar">
                            <span style="font-weight: 500;"><%= user.username %></span>
                        </div>
                        <a href="/messages/<%= user._id %>" class="modern-btn modern-btn-primary" style="padding: 0.5rem 1rem;">
                            <i class="fa fa-comment"></i>&nbsp;Chat
                        </a>
                    </li>
                    <% }) %>
                <% } %>
            </ul>
        </div>
    </main>

<%- include("partials/_footer") %>
